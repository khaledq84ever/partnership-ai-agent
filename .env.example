# ============================================================
# Partnership AI Agent — Environment Variables
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- n8n core ---
N8N_HOST=localhost
N8N_PROTOCOL=http
# Host port the n8n editor UI is published on (docker-compose maps
# N8N_PORT_HOST:5678 and start.sh prints this). Change THIS to move the UI;
# the in-container port stays 5678.
N8N_PORT_HOST=5678
WEBHOOK_URL=http://localhost:5678/
TZ=Asia/Kuwait
# Generate once: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_hex
# Basic auth for the n8n editor UI
N8N_USER=admin
N8N_PASSWORD=change_me_strong

# --- AI providers ---
# OpenAI — used for company analysis + lead scoring (structured JSON)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic — used for human-like email writing + negotiation
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01

# --- Company data / lead sourcing ---
# Apollo.io — company + contact discovery
APOLLO_API_KEY=...
# Clay — enrichment (optional; webhook-based)
CLAY_WEBHOOK_URL=

# --- CRM: Airtable (primary) ---
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_COMPANIES=Companies
AIRTABLE_TABLE_CONVERSATIONS=Conversations

# --- CRM: HubSpot (optional alternative) ---
HUBSPOT_ACCESS_TOKEN=

# --- Email: Gmail (primary) ---
# Configured inside n8n as a Gmail OAuth2 credential. Sender identity below:
SENDER_NAME=Partnerships Team
SENDER_EMAIL=khaledq8tv@gmail.com
SENDER_SIGNATURE=Best regards,\nPartnerships Team

# --- Email: Microsoft Graph (optional alternative) ---
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=

# --- Outreach guardrails ---
# Org you are representing (used in every AI prompt)
ORG_NAME=crafthost
ORG_ONE_LINER=Managed Minecraft & game server hosting platform
ORG_VALUE_PROP=Instant deploy, JVM tuning, Bedrock cross-play, global low-latency nodes
# Minimum lead score required before an email is auto-sent
MIN_SCORE_TO_SEND=70
# Max outreach emails sent per run (rate limiting)
MAX_SEND_PER_RUN=25
# Days to wait before an automated follow-up
FOLLOWUP_DAYS=4
# Max automated follow-ups per lead before we stop nudging (clears Next Follow-up)
MAX_FOLLOWUPS=3
